<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="24" style="-fx-background-color: #C8D8E8; -fx-padding: 36 48 36 48;"
      xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21"
      fx:controller="fr.univ_orleans.iut45.controleur.AjouterPieceControleur">

    <Label text="Ajouter une pièce"
           style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1E1E2E;"/>

    <Separator style="-fx-background-color: #AAAACC;"/>

    <VBox spacing="6">
        <Label text="Numéro de pièce"
               style="-fx-text-fill: #333344; -fx-font-size: 12; -fx-font-weight: bold;"/>
        <TextField fx:id="champNum"
                   promptText="ex: 3001"
                   prefWidth="340"
                   style="-fx-background-color: white; -fx-border-color: #AAAACC;
                          -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4;
                          -fx-font-size: 12; -fx-padding: 7 10 7 10;"/>
    </VBox>

    <VBox spacing="6">
        <Label text="Nom de la pièce"
               style="-fx-text-fill: #333344; -fx-font-size: 12; -fx-font-weight: bold;"/>
        <TextField fx:id="champNom"
                   promptText="ex: Brique 2x4"
                   prefWidth="340"
                   style="-fx-background-color: white; -fx-border-color: #AAAACC;
                          -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4;
                          -fx-font-size: 12; -fx-padding: 7 10 7 10;"/>
    </VBox>

    <VBox spacing="6">
        <Label text="Nom de la catégorie"
               style="-fx-text-fill: #333344; -fx-font-size: 12; -fx-font-weight: bold;"/>
        <TextField fx:id="champNomCat"
                   promptText="ex: Briques standards"
                   prefWidth="340"
                   style="-fx-background-color: white; -fx-border-color: #AAAACC;
                          -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4;
                          -fx-font-size: 12; -fx-padding: 7 10 7 10;"/>
    </VBox>

    <HBox spacing="12">
        <Button text="✚  Ajouter la pièce"
                onAction="#handleAjouter"
                style="-fx-background-color: #FF4D6A; -fx-text-fill: white;
                       -fx-font-size: 13; -fx-font-weight: bold;
                       -fx-background-radius: 5; -fx-cursor: hand;
                       -fx-padding: 9 22 9 22;"/>

        <Button text="Réinitialiser"
                onAction="#handleReset"
                style="-fx-background-color: transparent; -fx-text-fill: #555566;
                       -fx-font-size: 12; -fx-border-color: #AAAACC;
                       -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5;
                       -fx-cursor: hand; -fx-padding: 9 18 9 18;"/>
    </HBox>

    <Label fx:id="labelMessage" text="" wrapText="true"
           style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #333344;"/>

</VBox>
