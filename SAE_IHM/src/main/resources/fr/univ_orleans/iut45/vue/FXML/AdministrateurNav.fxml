<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600.0" prefWidth="228.0" style="-fx-background-color: #162032;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.univ_orleans.iut45.controleur.AdministrateurControleur">

    <Label style="-fx-text-fill: #5A7A9A; -fx-font-size: 9;                   -fx-font-weight: bold; -fx-padding: 16 16 6 16;" text="ADMINISTRATEUR" />

    <Button fx:id="btnAjouterBoite" maxWidth="Infinity" onAction="#handleAjouterBoite" onMouseEntered="#onNavHover" onMouseExited="#onNavExit" style="-fx-background-color: #FF4D6A; -fx-text-fill: white;                    -fx-font-size: 12; -fx-font-weight: bold;                    -fx-alignment: CENTER_LEFT; -fx-padding: 10 16 10 16;                    -fx-background-radius: 0; -fx-cursor: hand; -fx-border-width: 0;" text="Ajouter une boîte" />

    <Button fx:id="btnSupprimerBoite" maxWidth="Infinity" onAction="#handleSupprimerBoite" onMouseEntered="#onNavHover" onMouseExited="#onNavExit" style="-fx-background-color: transparent; -fx-text-fill: #B0C8E0;                    -fx-font-size: 12; -fx-alignment: CENTER_LEFT;                    -fx-padding: 10 16 10 16; -fx-background-radius: 0;                    -fx-cursor: hand; -fx-border-width: 0;" text="Supprimer une boîte" />

    <Button fx:id="btnMajContenuBoite" maxWidth="Infinity" onAction="#handleMajContenuBoite" onMouseEntered="#onNavHover" onMouseExited="#onNavExit" style="-fx-background-color: transparent; -fx-text-fill: #B0C8E0;                    -fx-font-size: 12; -fx-alignment: CENTER_LEFT;                    -fx-padding: 10 16 10 16; -fx-background-radius: 0;                    -fx-cursor: hand; -fx-border-width: 0;" text="Modifier le contenu d'une boîte" />

    <Separator style="-fx-background-color: #2A3F58; -fx-padding: 4 0 4 0;" />

    <Button fx:id="btnAjouterPiece" maxWidth="Infinity" onAction="#handleAjouterPiece" onMouseEntered="#onNavHover" onMouseExited="#onNavExit" style="-fx-background-color: transparent; -fx-text-fill: #B0C8E0;                    -fx-font-size: 12; -fx-alignment: CENTER_LEFT;                    -fx-padding: 10 16 10 16; -fx-background-radius: 0;                    -fx-cursor: hand; -fx-border-width: 0;" text="Ajouter une pièce" />

    <Button fx:id="btnSupprimerPiece" maxWidth="Infinity" onAction="#handleSupprimerPiece" onMouseEntered="#onNavHover" onMouseExited="#onNavExit" style="-fx-background-color: transparent; -fx-text-fill: #B0C8E0;                    -fx-font-size: 12; -fx-alignment: CENTER_LEFT;                    -fx-padding: 10 16 10 16; -fx-background-radius: 0;                    -fx-cursor: hand; -fx-border-width: 0;" text="Supprimer une pièce" />

    <Separator prefHeight="3.0" prefWidth="200.0" style="-fx-background-color: #2A3F58; -fx-padding: 4 0 4 0;" />

    <Button fx:id="btnCreerTheme" maxWidth="Infinity" onAction="#handleCreerTheme" onMouseEntered="#onNavHover" onMouseExited="#onNavExit" style="-fx-background-color: transparent; -fx-text-fill: #B0C8E0;                    -fx-font-size: 12; -fx-alignment: CENTER_LEFT;                    -fx-padding: 10 16 10 16; -fx-background-radius: 0;                    -fx-cursor: hand; -fx-border-width: 0;" text="Créer un thème" />

    <Region prefHeight="277.0" prefWidth="231.0" VBox.vgrow="ALWAYS" />

    <Separator style="-fx-background-color: #2A3F58;" />

    <Button fx:id="btnRetour" maxWidth="Infinity" onAction="#handleRetour" onMouseEntered="#onRetourHover" onMouseExited="#onRetourExit" style="-fx-background-color: transparent; -fx-text-fill: #5A7A9A;                    -fx-font-size: 11; -fx-alignment: CENTER_LEFT;                    -fx-padding: 12 16 12 16; -fx-background-radius: 0;                    -fx-cursor: hand; -fx-border-width: 0;" text="← Retour menu principal" />

</VBox>
