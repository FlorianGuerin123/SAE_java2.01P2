<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" style="-fx-background-color: #C8D8E8; -fx-padding: 30;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fr.univ_orleans.iut45.controleur.PiecesManquantesControleur">

    <Label style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1E3050;"
           text="Pièces manquantes de ma collection" />
    <Separator style="-fx-background-color: #AAAACC;" />

    
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Filtrer par boîte :" style="-fx-font-weight: bold;" />
        <TextField fx:id="champRecherche"
                   promptText="Numéro ou nom de boîte..."
                   style="-fx-font-size: 13; -fx-padding: 7; -fx-background-radius: 4;"
                   HBox.hgrow="ALWAYS" maxWidth="Infinity" />
        <Button fx:id="btnTout" onAction="#handleAfficherTout"
                text="Tout afficher"
                style="-fx-background-color: #1E3050; -fx-text-fill: white;
                       -fx-font-size: 12; -fx-padding: 7 14; -fx-background-radius: 4;
                       -fx-cursor: hand;" />
    </HBox>

    <VBox fx:id="menuDeroulant" managed="false" visible="false"
          style="-fx-background-color: white; -fx-border-color: #AAAACC;
                 -fx-border-radius: 4; -fx-background-radius: 4;" />

    
    <HBox spacing="20" alignment="CENTER_LEFT">
        <Label fx:id="labelResume"
               style="-fx-text-fill: #1E3050; -fx-font-size: 13; -fx-font-weight: bold;"
               text="" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="labelAucune"
               style="-fx-text-fill: #1A6B3C; -fx-font-size: 13; -fx-font-weight: bold;"
               text="" />
    </HBox>

    
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent;
                       -fx-border-color: transparent;">
        <VBox fx:id="zoneResultats" spacing="12"
              style="-fx-padding: 0 4 0 0;" />
    </ScrollPane>

</VBox>
