<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="24" style="-fx-background-color: #C8D8E8; -fx-padding: 36 48 36 48;"
      xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21"
      fx:controller="fr.univ_orleans.iut45.controleur.DetailBoiteControleur">

    <Label text="Détail d'une boîte"
           style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1E1E2E;"/>

    <Separator style="-fx-background-color: #AAAACC;"/>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="champNumero"
                   promptText="Numéro de la boîte  (ex: 71019)"
                   prefWidth="320"
                   style="-fx-background-color: white; -fx-border-color: #AAAACC;
                          -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4;
                          -fx-font-size: 12; -fx-padding: 7 10 7 10;"/>

        <Button text="🔍  Afficher le détail"
                onAction="#handleAfficher"
                style="-fx-background-color: #FF4D6A; -fx-text-fill: white;
                       -fx-font-size: 13; -fx-font-weight: bold;
                       -fx-background-radius: 5; -fx-cursor: hand;
                       -fx-padding: 9 22 9 22;"/>
    </HBox>

    <VBox fx:id="menuDeroulant" managed="false" visible="false" maxWidth="320" style="-fx-background-color: white; -fx-border-color: #AAAACC; -fx-border-radius: 4; -fx-background-radius: 4;" />

    <Label fx:id="labelMessage" text="" wrapText="true"
           style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #333344;"/>
       
    <ScrollPane fx:id="scrollResultats"
                fitToWidth="true"
                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;"
                VBox.vgrow="ALWAYS">

        <VBox fx:id="contenuDetail" spacing="20" visible="false" managed="false"
              style="-fx-background-color: transparent; -fx-padding: 4 4 4 4;">

            
            <VBox fx:id="carteInfo" spacing="10"
                  style="-fx-background-color: white; -fx-background-radius: 8;
                         -fx-border-color: #AAAACC; -fx-border-radius: 8; -fx-border-width: 1;
                         -fx-padding: 18 22 18 22;">

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label fx:id="labelNomBoite" text=""
                           style="-fx-font-size: 17; -fx-font-weight: bold; -fx-text-fill: #1E1E2E;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="labelNumBoite" text=""
                           style="-fx-background-color: #FF4D6A; -fx-text-fill: white;
                                  -fx-font-size: 11; -fx-font-weight: bold;
                                  -fx-background-radius: 12; -fx-padding: 4 12 4 12;"/>
                </HBox>

                <Separator style="-fx-background-color: #C8D8E8;"/>

                <HBox spacing="28">
                    <Label fx:id="labelAnnee" text=""
                           style="-fx-font-size: 12; -fx-text-fill: #333344;"/>
                    <Label fx:id="labelTheme" text=""
                           style="-fx-font-size: 12; -fx-text-fill: #333344;"/>
                    <Label fx:id="labelNbPieces" text=""
                           style="-fx-font-size: 12; -fx-text-fill: #333344;"/>
                </HBox>
            </VBox>

            
            <VBox fx:id="sectionPieces" spacing="10">
                <Label text="🧩  Pièces"
                       style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1E1E2E;"/>
                <FlowPane fx:id="flowPieces" hgap="10" vgap="10"/>
            </VBox>

            
            <VBox fx:id="sectionFigurines" spacing="10">
                <Label text="🧍  Figurines"
                       style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1E1E2E;"/>
                <FlowPane fx:id="flowFigurines" hgap="10" vgap="10"/>
            </VBox>

            
            <VBox fx:id="sectionSousBoites" spacing="10">
                <Label text="📦  Sous-boîtes incluses"
                       style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1E1E2E;"/>
                <FlowPane fx:id="flowSousBoites" hgap="10" vgap="10"/>
            </VBox>

        </VBox>

    </ScrollPane>

</VBox>
