<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600.0" prefWidth="228.0" style="-fx-background-color: #162032;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.univ_orleans.iut45.controleur.CollectionneurControleur">

    
    <Label style="-fx-text-fill: #5A7A9A; -fx-font-size: 9; -fx-font-weight: bold; -fx-padding: 16 16 6 16;" text="Collectionneur" />

    <Button fx:id="btnRechercher" maxWidth="Infinity" onAction="#handleRechercher" onMouseEntered="#onNavHover" onMouseExited="#onNavExit"
            style="-fx-background-color: #FF4D6A; -fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 10 16 10 16; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-width: 0;"
            text="🔍  Rechercher par numéro" />

    <Button fx:id="btnRechercherNom" maxWidth="Infinity" onAction="#handleRechercherNom" onMouseEntered="#onNavHover" onMouseExited="#onNavExit"
            style="-fx-background-color: transparent; -fx-text-fill: #B0C8E0; -fx-font-size: 12; -fx-alignment: CENTER_LEFT; -fx-padding: 10 16 10 16; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-width: 0;"
            text="  Rechercher par nom" />

    <Button fx:id="btnDetail" maxWidth="Infinity" onAction="#handleDetail" onMouseEntered="#onNavHover" onMouseExited="#onNavExit"
            style="-fx-background-color: transparent; -fx-text-fill: #B0C8E0; -fx-font-size: 12; -fx-alignment: CENTER_LEFT; -fx-padding: 10 16 10 16; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-width: 0;"
            text="  Détail d'une boîte" />

    <Button fx:id="btnTheme" maxWidth="Infinity" onAction="#handleTheme" onMouseEntered="#onNavHover" onMouseExited="#onNavExit"
            style="-fx-background-color: transparent; -fx-text-fill: #B0C8E0; -fx-font-size: 12; -fx-alignment: CENTER_LEFT; -fx-padding: 10 16 10 16; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-width: 0;"
            text="  Boîtes par thème" />

    <Button fx:id="btnStatistiques" maxWidth="Infinity" onAction="#handleStatistiques" onMouseEntered="#onNavHover" onMouseExited="#onNavExit"
            style="-fx-background-color: transparent; -fx-text-fill: #B0C8E0; -fx-font-size: 12; -fx-alignment: CENTER_LEFT; -fx-padding: 10 16 10 16; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-width: 0;"
            text="  Statistiques d'une boîte" />

    <Button fx:id="btnBoitesPiece" maxWidth="Infinity" onAction="#handleBoitesPiece" onMouseEntered="#onNavHover" onMouseExited="#onNavExit"
            style="-fx-background-color: transparent; -fx-text-fill: #B0C8E0; -fx-font-size: 12; -fx-alignment: CENTER_LEFT; -fx-padding: 10 16 10 16; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-width: 0;"
            text="  Boîtes contenant une pièce" />

    <Separator style="-fx-background-color: #2A3F58; -fx-padding: 4 0 4 0;" />

    
    <Label style="-fx-text-fill: #5A7A9A; -fx-font-size: 9; -fx-font-weight: bold; -fx-padding: 10 16 6 16;" text="MA COLLECTION" />

    <Button fx:id="btnMaCollection" maxWidth="Infinity" onAction="#handleMaCollection" onMouseEntered="#onNavHover" onMouseExited="#onNavExit"
            style="-fx-background-color: transparent; -fx-text-fill: #B0C8E0; -fx-font-size: 12; -fx-alignment: CENTER_LEFT; -fx-padding: 10 16 10 16; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-width: 0;"
            text="⭐  Afficher ma collection" />

    <Button fx:id="btnAjouterCollection" maxWidth="Infinity" onAction="#handleAjouterCollection" onMouseEntered="#onNavHover" onMouseExited="#onNavExit"
            style="-fx-background-color: transparent; -fx-text-fill: #B0C8E0; -fx-font-size: 12; -fx-alignment: CENTER_LEFT; -fx-padding: 10 16 10 16; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-width: 0;"
            text="  Ajouter à ma collection" />

    <Button fx:id="btnRetirerCollection" maxWidth="Infinity" onAction="#handleRetirerCollection" onMouseEntered="#onNavHover" onMouseExited="#onNavExit"
            style="-fx-background-color: transparent; -fx-text-fill: #B0C8E0; -fx-font-size: 12; -fx-alignment: CENTER_LEFT; -fx-padding: 10 16 10 16; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-width: 0;"
            text="  Retirer de ma collection" />

    <Button fx:id="btnPiecesManquantes" maxWidth="Infinity" onAction="#handlePiecesManquantes" onMouseEntered="#onNavHover" onMouseExited="#onNavExit"
            style="-fx-background-color: transparent; -fx-text-fill: #B0C8E0; -fx-font-size: 12; -fx-alignment: CENTER_LEFT; -fx-padding: 10 16 10 16; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-width: 0;"
            text="  Pièces manquantes" />

    <Button fx:id="btnComposer" maxWidth="Infinity" onAction="#handleComposer" onMouseEntered="#onNavHover" onMouseExited="#onNavExit"
            style="-fx-background-color: transparent; -fx-text-fill: #B0C8E0; -fx-font-size: 12; -fx-alignment: CENTER_LEFT; -fx-padding: 10 16 10 16; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-width: 0;"
            text="  Composer une boîte" />

    <Region VBox.vgrow="ALWAYS" />

    <Separator style="-fx-background-color: #2A3F58;" />

    <Button fx:id="btnRetour" maxWidth="Infinity" onAction="#handleRetour" onMouseEntered="#onRetourHover" onMouseExited="#onRetourExit"
            style="-fx-background-color: transparent; -fx-text-fill: #5A7A9A; -fx-font-size: 11; -fx-alignment: CENTER_LEFT; -fx-padding: 12 16 12 16; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-width: 0;"
            text="← Retour menu principal" />

</VBox>
