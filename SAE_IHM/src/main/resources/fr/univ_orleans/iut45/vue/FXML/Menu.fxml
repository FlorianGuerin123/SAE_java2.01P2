<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="400.0" prefWidth="700.0" style="-fx-background-color: #C8D8E8;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.univ_orleans.iut45.controleur.MainMenuControleur">

    <top>
        <HBox alignment="TOP_RIGHT" style="-fx-padding: 15 20 0 0;">
            <Button fx:id="btnDeconnexion" onAction="#handleDeconnexion" 
                    style="-fx-background-color: white; -fx-border-color: #FF4D6A; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: #FF4D6A; -fx-font-size: 11; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 6 12 6 12;" 
                    text="Déconnexion" />
        </HBox>
    </top>
    
    <center>
        <StackPane>

            
            <VBox alignment="CENTER" maxHeight="280" maxWidth="360" spacing="14" style="-fx-background-color: #D8E8F8;                        -fx-border-color: #FF4D6A;                        -fx-border-width: 2;                        -fx-border-radius: 6;                        -fx-background-radius: 6;                        -fx-padding: 30 40 30 40;">
                <StackPane.margin>
                    <Insets bottom="15.0" top="30.0" />
                </StackPane.margin>

                
                <HBox alignment="CENTER" spacing="8">
                    <Label style="-fx-font-size: 22;                                -fx-font-weight: bold;                                -fx-text-fill: #1E1E2E;" text="BRIQU'IUTO">
                    </Label>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
                </HBox>

               
                <Label style="-fx-font-size: 11;                            -fx-text-fill: #555566;" text="Gestion de collections de boîtes LEGO®" wrapText="true" />

                <Separator style="-fx-background-color: #AAAACC;" />

               
                <Label style="-fx-font-size: 12;                            -fx-text-fill: #333344;                            -fx-font-weight: bold;" text="Choisissez votre espace" />

        
                <Button fx:id="btnCollectionneur" maxWidth="Infinity" onAction="#handleCollectionneur" style="-fx-background-color: #FF4D6A;                            -fx-text-fill: white;                            -fx-font-size: 13;                            -fx-font-weight: bold;                            -fx-background-radius: 5;                            -fx-cursor: hand;                            -fx-padding: 10 0 10 0;" text="Espace Collectionneur" />

              
                <Label style="-fx-font-size: 10;                            -fx-text-fill: #666677;" text="Rechercher, consulter et gérer votre collection personnelle" wrapText="true" />

               
                <Button fx:id="btnAdministrateur" maxWidth="Infinity" onAction="#handleAdministrateur" style="-fx-background-color: transparent;                            -fx-border-color: #FF4D6A;                            -fx-border-width: 2;                            -fx-border-radius: 5;                            -fx-text-fill: #333344;                            -fx-font-size: 13;                            -fx-font-weight: bold;                            -fx-cursor: hand;                            -fx-padding: 10 0 10 0;" text="Espace Administrateur" />

               
                <Label style="-fx-font-size: 10;                            -fx-text-fill: #666677;" text="Gérez les boîtes, pièces et thèmes de la base de données" wrapText="true" />

                <Button fx:id="btnQuitter" onAction="#handleQuitter" style="-fx-background-color: transparent;                            -fx-border-color: #AAAACC;                            -fx-border-width: 1;                            -fx-border-radius: 4;                            -fx-text-fill: #555566;                            -fx-font-size: 11;                            -fx-cursor: hand;                            -fx-padding: 6 18 6 18;" text="✕  Quitter l'application" />

            </VBox>

        </StackPane>
    </center>

   
    <bottom>
        <HBox alignment="CENTER" style="-fx-padding: 6;">
            <Label style="-fx-font-size: 9;                        -fx-text-fill: #888899;" text="BRIQU'IUTO — Gestion de collections" />
        </HBox>
    </bottom>

</BorderPane>
